class Solution {
public:
    int removeElement(vector<int>& nums, int val) {
        int left=0;
        int right=nums.size()-1;

        for(int i=0;i<nums.size()-1;i++)
        {
            if(nums[left]!=val)
            {
                left++;
            }
            else{
                if(nums[right]==val)
                {
                    right--;
                }
                nums[left]=nums[right];
                nums[right]=val;
            }
        }
        return left;
        
    }
};
