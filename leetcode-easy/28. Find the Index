class Solution {
public:
    int strStr(string haystack, string needle) {

        //have left indices for both haystack and needle
        //compare both, traverse haystack till a match is found
        // once a match is found, compare right of needle and haystack
        //if they match, traverse both rights till  right index = left index?
        int n=haystack.length();
        int m=needle.length();

        for(int i=0;i<=n-m;i++){
            int j=0;
            while(j<m && haystack[i+j]==needle[j]){
                j++;
            }

            if(j==m){
                return i;
            }
        }
        return -1;
             
    }
};
