class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        
        int n=nums.size();
        int currsum=0;

        for (int i=0;i<k;i++)
        {
            currsum+=nums[i];
        }

        int maxAvg=currsum;

        for(int i=k; i<n; i++)
        {
            currsum+=nums[i];
            currsum-=nums[i-k];
            maxAvg=max(maxAvg, currsum);
        }

        return (double)maxAvg / k;
    }
};
