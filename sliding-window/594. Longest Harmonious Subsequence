class Solution {
public:
    int findLHS(vector<int>& nums) {

        sort(nums.begin(), nums.end());

        int left = 0;
        int ans = 0;

        for(int right=0;right<nums.size();right++)
        {
            while (nums[right]-nums[left]>1) // move sliding window if 
                                            // biggest - smallest > 1
                left++;
            
            if (nums[right] - nums[left] == 1) //store in longest subseq count
                ans = max(ans, right - left + 1);
        }

        return ans;
          
    }
};

